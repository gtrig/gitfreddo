#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

if ! git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

cd "$ROOT"

# Load NVM so the hook uses the Node.js version declared in .nvmrc.
# Git hooks run outside the interactive shell, so NVM is not available by default.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
# shellcheck source=/dev/null
[[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh" --no-use
if command -v nvm &>/dev/null && [[ -f "$ROOT/.nvmrc" ]]; then
  nvm use --silent 2>/dev/null || true
fi

# Fail fast with a clear message if the above didn't actually get us onto
# the right Node version (or a dependency bump broke jsdom), instead of
# discovering it 40s into a test run via a wall of duplicated stack traces.
bash "$ROOT/scripts/check-test-env.sh"

echo "Running pre-commit checks (typecheck, test)..." >&2
npm run typecheck
npm run test
