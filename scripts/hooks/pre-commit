#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

if ! git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

cd "$ROOT"

# Get the hook onto the Node.js version declared in .nvmrc. Git hooks run in
# a minimal, non-interactive shell, so nvm/fnm's shell integration (which
# normally auto-switches on `cd`) never fires, and whatever "node" happens to
# be first on PATH (system package, another tool's bundled Node, ...) wins
# instead. `nvm use` alone isn't enough either: if the required version was
# never installed, it fails silently and leaves PATH untouched — which is
# exactly the class of bug that kept causing cryptic jsdom failures here.
# So: install if missing, then use, for whichever version manager exists.
if [[ -f "$ROOT/.nvmrc" ]]; then
  REQUIRED_NODE="$(cat "$ROOT/.nvmrc")"
  REQUIRED_NODE="${REQUIRED_NODE//[$'\t\r\n ']/}"

  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    # shellcheck source=/dev/null
    source "$NVM_DIR/nvm.sh" --no-use
    if command -v nvm &>/dev/null; then
      if ! nvm use "$REQUIRED_NODE" --silent 2>/dev/null; then
        nvm install "$REQUIRED_NODE" --silent 2>/dev/null || true
        nvm use "$REQUIRED_NODE" --silent 2>/dev/null || true
      fi
    fi
  elif command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd 2>/dev/null || true)"
    fnm use "$REQUIRED_NODE" --install-if-missing --silent-if-unchanged 2>/dev/null || true
  fi
fi

# Fail fast with a clear message if the above didn't actually get us onto
# the right Node version (or a dependency bump broke jsdom), instead of
# discovering it 40s into a test run via a wall of duplicated stack traces.
bash "$ROOT/scripts/check-test-env.sh"

echo "Running pre-commit checks (typecheck, test)..." >&2
npm run typecheck
npm run test
