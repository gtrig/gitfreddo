# Optional overrides (also configurable in ~/.config/gitfreddo/settings.json)
# GIT_BINARY=/usr/bin/git

# Loaded into the Electron main process from project-root .env (dev / local).
# electron-vite also bakes these into release builds when set in the build environment
# (GitHub Actions: secrets GITFREDDO_GITHUB_CLIENT_ID, BITBUCKET_CLIENT_ID,
# BITBUCKET_CLIENT_SECRET, GITLAB_CLIENT_ID, GITLAB_CLIENT_SECRET).

# GitHub OAuth App client ID (Device Flow; app requests repo + admin:public_key)
# GITHUB_CLIENT_ID=your_oauth_app_client_id

# Optional GitHub Enterprise Server hostname (e.g. github.mycompany.com)
# GITHUB_ENTERPRISE_HOST=github.mycompany.com

# Bitbucket OAuth consumer (callback http://127.0.0.1:8765/callback)
# BITBUCKET_CLIENT_ID=your_consumer_key
# BITBUCKET_CLIENT_SECRET=your_consumer_secret

# GitLab OAuth application (callback http://127.0.0.1:8785/callback; scopes api + read_user)
# GITLAB_CLIENT_ID=your_application_id
# GITLAB_CLIENT_SECRET=your_application_secret
# Optional self-managed hostname (leave unset for gitlab.com)
# GITLAB_HOST=gitlab.mycompany.com
