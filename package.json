{
  "name": "gitfreddo",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop git client with commit graph",
  "author": "George Trigonakis <gtrig84@gmail.com>",
  "homepage": "https://github.com/gtrig/gitfreddo",
  "desktopName": "gitfreddo.desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtrig/gitfreddo.git"
  },
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "CHROME_DESKTOP=gitfreddo.desktop NO_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "NO_SANDBOX=1 electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "smoke": "bash scripts/smoke-test.sh"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.90.2",
    "@xyflow/react": "^12.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.13.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.arctosweblabs.gitfreddo",
    "productName": "GitFreddo",
    "protocols": [
      {
        "name": "GitFreddo OAuth",
        "schemes": [
          "gitfreddo"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "assets/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/linux/icons",
      "category": "Development",
      "maintainer": "ArctosWebLabs <gtrig@users.noreply.github.com>"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/logo.ico"
    }
  }
}
